---
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.svelte';
import LangPicker from '../components/LangPicker.svelte';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const {
  title = 'Phlik Career · พลิกอาชีพ — AI career coach',
  description = 'AI career coach for SEA professionals. Resume polish, interview prep, career journal. Free during beta.',
  canonical = 'https://phlik.kasion.dev/',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kasion" />
    <meta name="theme-color" content="#020617" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="192x192" href="/phlik-icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/phlik-icon.png" />
    <link rel="shortcut icon" href="/phlik-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Phlik Career" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://phlik.kasion.dev/phlik-icon.png" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://phlik.kasion.dev/phlik-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sarabun:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'Sarabun', 'system-ui', 'sans-serif'],
              mono: ['JetBrains Mono', 'monospace'],
              thai: ['Sarabun', 'system-ui', 'sans-serif'],
            },
            colors: {
              ink: {
                950: '#020617',
                900: '#0f172a',
                800: '#1e293b',
                700: '#334155',
                500: '#64748b',
                300: '#cbd5e1',
                100: '#f1f5f9',
              },
              ion: {
                300: '#67e8f9',
                400: '#22d3ee',
                500: '#06b6d4',
                600: '#0891b2',
              },
              gold: {
                300: '#fde68a',
                400: '#fcd34d',
                500: '#f59e0b',
              },
            },
          },
        },
      };
    </script>

    <style is:global>
      html, body { background: #020617; }
      body {
        font-family: 'Inter', 'Sarabun', system-ui, sans-serif;
        color: #f1f5f9;
        min-height: 100vh;
        overflow-x: hidden;
      }
      .grid-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        background-image:
          linear-gradient(rgba(34, 211, 238, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(34, 211, 238, 0.05) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 75%);
        pointer-events: none;
      }
      .orb {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.25;
        pointer-events: none;
        z-index: 0;
      }
      .orb-1 {
        top: -200px;
        right: -150px;
        background: radial-gradient(circle, #22d3ee 0%, transparent 60%);
      }
      .orb-2 {
        bottom: -200px;
        left: -150px;
        background: radial-gradient(circle, #f59e0b 0%, transparent 60%);
      }
      .wordmark {
        background: linear-gradient(135deg, #67e8f9 0%, #22d3ee 40%, #fcd34d 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.02em;
      }
      .pulse-dot {
        position: relative;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #22d3ee;
        box-shadow: 0 0 12px #22d3ee;
      }
      .pulse-dot::after {
        content: '';
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        border: 1px solid #22d3ee;
        animation: pulse 2s ease-out infinite;
      }
      @keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(2.2); opacity: 0; }
      }
      .btn-ion {
        background: linear-gradient(135deg, #22d3ee 0%, #0891b2 100%);
        color: #020617;
        font-weight: 600;
        transition: all 0.2s ease;
      }
      .btn-ion:hover {
        box-shadow: 0 0 30px rgba(34, 211, 238, 0.35);
        transform: translateY(-1px);
      }
      .btn-ion:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
      }
      .input-glow:focus {
        outline: none;
        border-color: #22d3ee;
        box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.15);
      }
    </style>
  </head>
  <body class="relative">
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <header class="relative z-10 px-6 md:px-10 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group" aria-label="Phlik Career home">
        <img
          src="/phlik-icon.png"
          alt=""
          width="36"
          height="36"
          class="w-9 h-9 rounded-lg ring-1 ring-ink-700/60 group-hover:ring-ion-400/60 transition-all"
        />
        <div class="flex flex-col leading-none">
          <span class="font-semibold tracking-tight text-ink-100 text-sm">Phlik Career</span>
          <span class="font-mono text-[10px] text-ink-500 mt-0.5">phlik.kasion.dev</span>
        </div>
      </a>
      <nav class="flex items-center gap-3 md:gap-5 text-xs font-mono text-ink-500">
        <Nav client:load />
      </nav>
    </header>

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 px-6 md:px-10 py-8 border-t border-ink-800/50 mt-12">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs font-mono text-ink-500">
        <Footer client:load />
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <LangPicker client:load />
          <a href="https://kasion.dev" target="_blank" rel="noopener" class="hover:text-ion-400 transition-colors">kasion.dev</a>
          <a href="https://play.google.com/store/apps/details?id=dev.kasion.phlik.career" target="_blank" rel="noopener" class="hover:text-ion-400 transition-colors">android</a>
          <a href="mailto:hello@kasion.dev" class="hover:text-ion-400 transition-colors">hello@kasion.dev</a>
        </div>
      </div>
    </footer>
  </body>
</html>
